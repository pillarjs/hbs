{
  "name": "hbs",
  "description": "Express.js template engine plugin for Handlebars",
  "version": "4.2.0",
  "author": "Don Park <donpark@docuverse.com> (http://blog.docuverse.com)",
  "contributors": [
    "Roman Shtylman <shtylman@gmail.com>"
  ],
  "license": "MIT",
  "repository": "pillarjs/hbs",
  "main": "lib/hbs.js",
  "dependencies": {
    "handlebars": "4.7.8",
    "walk": "2.3.15"
  },
  "devDependencies": {
    "@vitest/coverage-v8": "^4.0.18",
    "eslint": "7.32.0",
    "eslint-plugin-markdown": "2.2.1",
    "express": "^5.2.1",
    "supertest": "6.1.6",
    "vitest": "^4.0.18"
  },
  "files": [
    "lib/",
    "HISTORY.md",
    "LICENSE",
    "README.md"
  ],
  "engines": {
    "node": ">= 18"
  },
  "scripts": {
    "lint": "eslint .",
    "test": "vitest run",
    "test-ci": "vitest run --coverage --coverage.reporter=lcov --coverage.reporter=text",
    "test-cov": "vitest run --coverage --coverage.reporter=html --coverage.reporter=text"
  }
